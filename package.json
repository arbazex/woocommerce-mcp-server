{
  "name": "@arbazasif/woocommerce-mcp-server",
  "version": "1.0.0",
  "description": "Production-grade Model Context Protocol (MCP) server for WooCommerce — manage orders, products, customers, inventory and analytics with Claude AI or any MCP client",
  "main": "build/index.js",
  "type": "module",
  "bin": {
    "woocommerce-mcp-server": "./build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node build/index.js",
    "inspect": "npx @modelcontextprotocol/inspector build/index.js",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "woocommerce",
    "wordpress",
    "woocommerce-ai",
    "woocommerce-agent",
    "claude",
    "claude-mcp",
    "ai-agent",
    "ecommerce-ai",
    "woocommerce-automation",
    "woocommerce-claude",
    "shop-management",
    "order-management",
    "inventory-management",
    "anthropic",
    "llm-tools"
  ],
  "author": "arbazasif",
  "license": "MIT",
  "homepage": "https://github.com/arbazex/woocommerce-mcp-server",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arbazex/woocommerce-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/arbazex/woocommerce-mcp-server/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "axios": "^1.9.0",
    "axios-retry": "^4.5.0",
    "zod": "^3.25.20"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "typescript": "^5.8.3"
  }
}
